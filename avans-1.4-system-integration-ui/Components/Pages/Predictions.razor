@page "/predictions"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject PredictionsService PredictionsService

<PageTitle>Predictions</PageTitle>

<AuthorizeView>
    <Authorized>
        <h1>Predictions</h1>

        <h1 class="page-title">Predictions</h1>

        @* Kaart *@
        <div id="map" class="mb-4"></div>

        @* Input formulier *@
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Voorspelling invoer</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Datum</label>
                        <input type="date" class="form-control" @bind="inputDatum" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Temperatuur (°C)</label>
                        <input type="number" class="form-control" @bind="inputTemperatuur" placeholder="bijv. 18" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Weertype</label>
                        <select class="form-select" @bind="inputWeertype">
                            <option value="">-- Selecteer weertype --</option>

                            @foreach (var weertype in Weertypes)
                            {
                                <option value="@weertype.Key">
                                    @weertype.Value
                                </option>
                            }
                        </select>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(validatieFout))
                {
                    <div class="alert alert-danger mt-3">@validatieFout</div>
                }

                <div class="mt-3">
                    <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="VoorspellingOphalen" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span>
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Voorspelling laden...
                            </span>
                        }
                        else
                        {
                            <span>Voorspelling ophalen</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        @* Charts *@
        <div class="row g-4 mt-2">
            @* Bar Chart / Prioriteitskaart *@
            <div class="col-12 col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Voorspelling</h5>
                    </div>

                    <div class="card-body">

                        @if (voorspellingResponse != null)
                        {
                            <div class="mb-4">
                                <h6>Prioriteit</h6>

                                <div class="alert alert-primary">
                                    <strong>Basisprioriteit:</strong>
                                    @(Prioriteiten.TryGetValue(voorspellingResponse.BasePriority ?? "", out var basisPrioriteit)
                                        ? basisPrioriteit
                                        : voorspellingResponse.BasePriority)
                                </div>

                                <div class="alert alert-success">
                                    <strong>Eindprioriteit:</strong>
                                    @(Prioriteiten.TryGetValue(voorspellingResponse.FinalPriority ?? "", out var eindPrioriteit)
                                        ? eindPrioriteit
                                        : voorspellingResponse.FinalPriority)
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(voorspellingResponse.Explanation))
                            {
                                <div>
                                    <h6>Toelichting</h6>

                                    <div class="alert alert-secondary">
                                        @* Vertaal basistekst uit API indien deze 'paper/cardboard' bevat *@
                                        @voorspellingResponse.Explanation.Replace("paper/cardboard", "papier/karton", StringComparison.OrdinalIgnoreCase)
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">
                                Vraag een voorspelling op om resultaten te bekijken.
                            </p>
                        }

                    </div>
                </div>
            </div>

            @* Polar Area Chart *@
            <div class="col-12 col-lg-5">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Verdeling per afvaltype</h5>
                        <small class="text-muted">Kans berekening (%)</small>
                    </div>
                    <div class="card-body">
                        <PolarAreaChart @ref="polarAreaChart" Width="400" />
                    </div>
                    <div class="card-footer text-muted">
                        <i class="bi bi-calendar-event me-1"></i>
                        Evenement in de buurt:
                        <strong>
                            @(voorspellingResponse?.NearbyEvents?.FirstOrDefault()?.Name ?? "Geen evenement")
                        </strong>
                    </div>
                </div>
            </div>
        </div>


    </Authorized>
    <NotAuthorized>
        <p>Je moet ingelogd zijn om deze pagina te bekijken.</p>
        <a href="/account/login">Inloggen</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private PolarAreaChart polarAreaChart = default!;
    private PolarAreaChartOptions polarAreaChartOptions = default!;
    private ChartData polarChartData = default!;

    private double markerLat;
    private double markerLng;
    private static Action<double, double>? _onMarkerGeplaatst;

    // Inputs
    private DateTime inputDatum = DateTime.Today;
    private double? inputTemperatuur;
    private string inputWeertype = "";
    private string validatieFout = "";
    private bool isLoading = false;

    // BUGFIX: StringComparer.OrdinalIgnoreCase toegevoegd zodat 'medium' en 'Medium' allebei matchen
    private readonly Dictionary<string, string> Weertypes = new(StringComparer.OrdinalIgnoreCase)
    {
        { "Sunny", "Zonnig" },
        { "Cloudy", "Bewolkt" },
        { "Rain", "Regen" },
        { "Fog", "Mist" },
        { "Storm", "Storm" }
    };

    // BUGFIX: StringComparer.OrdinalIgnoreCase toegevoegd zodat 'medium' en 'Medium' allebei matchen
    private readonly Dictionary<string, string> Prioriteiten = new(StringComparer.OrdinalIgnoreCase)
    {
        { "Low", "Laag" },
        { "Medium", "Gemiddeld" },
        { "High", "Hoog" },
        { "Critical", "Kritiek" }
    };

    private PredictionResponseDto? voorspellingResponse;

    private static readonly string[] WasteTypes =
    [
        "Plastic",
        "Papier/Karton",
        "Glas",
        "Blik",
        "Elektronica",
        "Grofvuil",
        "Restafval"
    ];
    private static readonly Dictionary<string, string> Afvaltypes = new(StringComparer.OrdinalIgnoreCase)
    {
        { "Plastic", "Plastic" },
        { "Paper", "Papier/Karton" },
        { "Glass", "Glas" },
        { "Metal", "Blik" },
        { "Electronics", "Elektronica" },
        { "Bulky", "Grofvuil" },
        { "Residual", "Restafval" }
    };

    private static readonly List<string> BackgroundColors =
    [
        "rgba(13, 110, 253, 0.8)",
        "rgba(25, 135, 84, 0.8)",
        "rgba(255, 193, 7, 0.8)",
        "rgba(220, 53, 69, 0.8)",
        "rgba(102, 16, 242, 0.8)",
        "rgba(13, 202, 240, 0.8)",
        "rgba(255, 102, 0, 0.8)",
    ];

    private static readonly List<string> BorderColors =
    [
        "rgb(13, 110, 253)",
        "rgb(25, 135, 84)",
        "rgb(255, 193, 7)",
        "rgb(220, 53, 69)",
        "rgb(102, 16, 242)",
        "rgb(13, 202, 240)",
        "rgb(255, 102, 0)",
    ];

    private bool chartsInitialized = false;

    protected override void OnInitialized()
    {
        _onMarkerGeplaatst = (lat, lng) =>
        {
            markerLat = lat;
            markerLng = lng;
            InvokeAsync(StateHasChanged);
        };

        BuildLegeChartData();
    }

    [JSInvokable]
    public static void OnMarkerGeplaatst(double lat, double lng)
    {
        _onMarkerGeplaatst?.Invoke(lat, lng);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initMapPredictions");
            await polarAreaChart.InitializeAsync(polarChartData, polarAreaChartOptions);
            chartsInitialized = true;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private bool Valideer()
    {
        if (inputTemperatuur == null)
        {
            validatieFout = "Vul een temperatuur in.";
            return false;
        }
        if (string.IsNullOrEmpty(inputWeertype))
        {
            validatieFout = "Selecteer een weertype.";
            return false;
        }
        if (markerLat == 0 || markerLng == 0)
        {
            validatieFout = "Plaats een marker op de kaart om een locatie te selecteren.";
            return false;
        }

        validatieFout = "";
        return true;
    }

    private async Task VoorspellingOphalen()
    {
        if (!Valideer()) return;

        isLoading = true;
        StateHasChanged();

        try
        {
            var request = new PredictionRequestDto
            {
                DateTime = inputDatum,
                Temperature = inputTemperatuur!.Value,
                WeatherType = inputWeertype,
                Latitude = markerLat,
                Longitude = markerLng,
            };

            voorspellingResponse = await PredictionsService.PredictAsync(request);

            if (voorspellingResponse != null)
                BuildChartDataVanResponse(voorspellingResponse);

            if (chartsInitialized)
            {
                await polarAreaChart.UpdateAsync(polarChartData, polarAreaChartOptions);
            }
        }
        catch (Exception ex)
        {
            validatieFout = $"Fout bij ophalen voorspelling: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BuildChartDataVanResponse(PredictionResponseDto response)
    {
        var kansen = WasteTypes.Select(type =>
        {
            var engelsType = Afvaltypes
                .FirstOrDefault(x => x.Value == type)
                .Key;

            var match = response.TrashTypeProbabilities
                .FirstOrDefault(p =>
                    p.Label?.Equals(engelsType, StringComparison.OrdinalIgnoreCase) == true);
            return match != null ? Math.Round(match.Probability * 100, 1) : 0.0;
        }).ToArray();

        polarChartData = new ChartData
        {
            Labels = [.. WasteTypes],
            Datasets =
            [
                new PolarAreaChartDataset
                {
                    Label = "Kans (%)",
                    Data = [.. kansen.Select(d => (double?)d)],
                    BackgroundColor = BackgroundColors,
                    BorderColor = BorderColors,
                    BorderWidth = new List<double> { 1.5 },
                }
            ]
        };

        polarAreaChartOptions = new PolarAreaChartOptions { Responsive = true };
        polarAreaChartOptions.Plugins.Legend.Position = "bottom";
    }

    private void BuildLegeChartData()
    {
        var leeg = WasteTypes.Select(_ => (double?)0).ToList();

        polarChartData = new ChartData
        {
            Labels = [.. WasteTypes],
            Datasets =
            [
                new PolarAreaChartDataset
                {
                    Label = "Kans (%)",
                    Data = leeg,
                    BackgroundColor = BackgroundColors,
                    BorderColor = BorderColors,
                    BorderWidth = new List<double> { 1.5 },
                }
            ]
        };

        polarAreaChartOptions = new PolarAreaChartOptions { Responsive = true };
        polarAreaChartOptions.Plugins.Legend.Position = "bottom";
    }
}