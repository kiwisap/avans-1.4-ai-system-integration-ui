@page "/Heatmap"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject TrashDataService TrashDataService
@using avans_1._4_system_integration_ui.Models.Enums

<PageTitle>Heatmap</PageTitle>

<h1 class="heatmap-title">
    <span class="bi bi-map me-2"></span>Heatmap
</h1>

<div class="filter-bar">
    <button class="pill" @onclick='() => LoadData(1)'>1 dag</button>
    <button class="pill" @onclick='() => LoadData(7)'>1 week</button>
    <button class="pill" @onclick='() => LoadData(30)'>1 maand</button>
    <button class="pill" @onclick='() => LoadData(90)'>3 maanden</button>
    <button class="pill" @onclick='() => LoadData(180)'>6 maanden</button>
    <button class="pill" @onclick='() => LoadData(365)'>1 jaar</button>
    <button class="pill" @onclick='() => LoadData(null)'>Alles</button>
</div>

<div style="position: relative;">
    @if (_isLoading)
    {
        <div class="map-loading-overlay">
            <div class="map-loading-inner">
                <div class="spinner-border text-success" role="status"></div>
                <span>Gegevens laden...</span>
            </div>
        </div>
    }
    <div id="map"></div>
</div>

<div class="card p-3 mt-3">
    <h5 class="mb-3" style="color: #2d6a4f; font-weight: 600;">
        <span class="bi bi-palette me-2"></span>Legenda
    </h5>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot red"></span><span>Plastic</span></div>
            <span style="font-size: 12px; background: #fee2e2; color: #991b1b; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 7</span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot blue"></span><span>Papier/karton</span></div>
            <span style="font-size: 12px; background: #dbeafe; color: #1e40af; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 4</span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot goldenrod"></span><span>Glas</span></div>
            <span style="font-size: 12px; background: #fef9c3; color: #854d0e; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 9</span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot green"></span><span>Blik</span></div>
            <span style="font-size: 12px; background: #dcfce7; color: #166534; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 6</span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot purple"></span><span>Elektrische apparaten</span></div>
            <span style="font-size: 12px; background: #ede9fe; color: #5b21b6; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 10</span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot orange"></span><span>Grofvuil</span></div>
            <span style="font-size: 12px; background: #ffedd5; color: #9a3412; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 8</span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;"><span class="dot hotpink"></span><span>Restafval</span></div>
            <span style="font-size: 12px; background: #fce7f3; color: #9d174d; padding: 2px 10px; border-radius: 999px; font-weight: 500;">Score: 5</span>
        </div>
    </div>

    <p class="mt-3 mb-0" style="font-size: 13px; color: #6b7280;">
        <span class="bi bi-info-circle me-1"></span>
        De prioriteitsscore wordt berekend door het aantal stukken afval te vermenigvuldigen met de score van elk type.<br />
        Dus hoe hoger de prioriteits score hoe belangrijker het is om het op te ruimen.
    </p>
</div>

@code {
    private bool _isLoading = false;

    private static readonly Dictionary<TrashType, string> TrashTypeLabels = new()
    {
        { TrashType.Plastic,    "Plastic" },
        { TrashType.Paper,      "Papier/karton" },
        { TrashType.Glass,      "Glas" },
        { TrashType.Can,        "Blik" },
        { TrashType.Bulky_Waste,"Grofvuil" },
        { TrashType.Rest,       "Restafval" },
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await JS.InvokeVoidAsync("initMap");
        await LoadData(10);
    }

    private async Task LoadData(int? days)
    {
        _isLoading = true;
        StateHasChanged();

        var startDate = days.HasValue
            ? DateTime.UtcNow.AddDays(-days.Value)
            : DateTime.MinValue;

        var trashData = await TrashDataService.GetTrashDataAsync(new TrashDataTimeFrameDto
        {
            StartDate = startDate,
            EndDate = DateTime.UtcNow
        });

        var mapped = trashData.Select(item => new
        {
            item.Id,
            item.SensorId,
            TrashType = TrashTypeLabels.TryGetValue(item.TrashType, out var label) ? label : item.TrashType.ToString(),
            item.Latitude,
            item.Longitude,
            item.DateTime,
            item.Temperature,
            item.Rain,
            item.Confidence,
            item.ImageId,
            item.FetchedAtUtc
        }).ToList();

        await JS.InvokeVoidAsync("loadTrashData", mapped);

        _isLoading = false;
        StateHasChanged();
    }
}