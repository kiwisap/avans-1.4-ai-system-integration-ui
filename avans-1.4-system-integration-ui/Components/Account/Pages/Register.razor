@page "/account/register"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using avans_1._4_system_integration_ui.Services
@using avans_1._4_system_integration_ui.Models

@inject AuthService AuthService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Registreren</PageTitle>

<div class="tp-auth-wrapper">
    <div class="tp-auth-card">

        <h2>Registreren</h2>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="tp-auth-error">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="tp-auth-success">@successMessage</div>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="RegisterUser">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <InputText @bind-Value="Input.Name"
                           class="form-control"
                           placeholder="Naam" />
                <ValidationMessage For="() => Input.Name" class="text-danger" />
            </div>

            <div class="mb-3">
                <InputText @bind-Value="Input.Email"
                           class="form-control"
                           placeholder="Email" />
                <ValidationMessage For="() => Input.Email" class="text-danger" />
            </div>

            <div class="mb-3">
                <InputText type="password"
                           @bind-Value="Input.Password"
                           class="form-control"
                           placeholder="Wachtwoord" />
                <ValidationMessage For="() => Input.Password" class="text-danger" />
            </div>

            <div class="mb-3">
                <InputText type="password"
                           @bind-Value="Input.ConfirmPassword"
                           class="form-control"
                           placeholder="Bevestig wachtwoord" />
                <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
            </div>

            <button type="submit"
                    class="tp-auth-btn"
                    disabled="@isLoading">

                @if (isLoading)
                {
                    <span>Registreren...</span>
                }
                else
                {
                    <span>Account aanmaken</span>
                }
            </button>
        </EditForm>

        <a class="tp-auth-link" href="/account/login">
            Al een account? Inloggen
        </a>

    </div>
</div>

@code {
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = false;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override void OnInitialized()
    {
        Input ??= new();
    }

    public async Task RegisterUser()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var request = new RegisterRequestDto
            {
                Name = Input.Name,
                Email = Input.Email,
                Password = Input.Password
            };

            var response = await AuthService.RegisterAsync(request);

            if (response.Success)
            {
                successMessage = "Registratie succesvol! Doorverwijzen...";
                await Task.Delay(800);
                NavigationManager.NavigateTo("/account/login", forceLoad: true);
            }
            else
            {
                errorMessage = response.Message ?? "Registratie mislukt.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Naam is verplicht")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Email is verplicht")]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Wachtwoord is verplicht")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Bevestig je wachtwoord")]
        [Compare("Password", ErrorMessage = "Wachtwoorden komen niet overeen")]
        public string ConfirmPassword { get; set; } = "";
    }
}