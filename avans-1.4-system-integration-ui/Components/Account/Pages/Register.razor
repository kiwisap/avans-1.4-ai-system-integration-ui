@page "/account/register"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using avans_1._4_system_integration_ui.Services
@using avans_1._4_system_integration_ui.Models

@inject AuthService AuthService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Registreren</PageTitle>

<h1>Registreren</h1>

<div class="row">
    <div class="col-lg-6">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" role="alert">@successMessage</div>
        }
        <EditForm Model="Input" method="post" OnValidSubmit="RegisterUser" FormName="register">
            <DataAnnotationsValidator />
            <h2>Maak een nieuw account aan.</h2>
            <hr />
            <ValidationSummary class="text-danger" role="alert" />
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.Name" id="Input.Name" class="form-control" autocomplete="name" aria-required="true" placeholder="Jan Jansen" />
                <label for="Input.Name">Naam</label>
                <ValidationMessage For="() => Input.Name" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.Email" id="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="naam@voorbeeld.nl" />
                <label for="Input.Email">Email</label>
                <ValidationMessage For="() => Input.Email" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="wachtwoord" />
                <label for="Input.Password">Wachtwoord</label>
                <ValidationMessage For="() => Input.Password" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText type="password" @bind-Value="Input.ConfirmPassword" id="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="wachtwoord" />
                <label for="Input.ConfirmPassword">Bevestig wachtwoord</label>
                <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Registreren...</span>
                }
                else
                {
                    <span>Registreren</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@code {
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = false;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override void OnInitialized()
    {
        Input ??= new();
    }

    public async Task RegisterUser()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var request = new RegisterRequestDto
            {
                Name = Input.Name,
                Email = Input.Email,
                Password = Input.Password
            };

            var response = await AuthService.RegisterAsync(request);

            if (response.Success)
            {
                successMessage = "Registratie succesvol! Doorverwijzen naar inlogpagina...";
                await Task.Delay(1000);
                NavigationManager.NavigateTo("/account/login", forceLoad: true);
            }
            else
            {
                errorMessage = response.Message ?? "Registratie mislukt.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Naam is verplicht")]
        [Display(Name = "Naam")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Email is verplicht")]
        [EmailAddress(ErrorMessage = "Ongeldig email adres")]
        [Display(Name = "Email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Wachtwoord is verplicht")]
        [StringLength(100, ErrorMessage = "Het {0} moet minimaal {2} en maximaal {1} tekens lang zijn.", MinimumLength = 8)]
        [DataType(DataType.Password)]
        [Display(Name = "Wachtwoord")]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Bevestig wachtwoord")]
        [Compare("Password", ErrorMessage = "Het wachtwoord en bevestigingswachtwoord komen niet overeen.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
